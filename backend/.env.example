# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Public URL of this backend (used by Swagger UI to point API calls at the right host)
# On Render set this to your Render service URL, e.g. https://proj-01-hy9i.onrender.com
BACKEND_URL=http://localhost:4000

# ─────────────────────────────────────────────
# DATABASE (Supabase PostgreSQL)
# ─────────────────────────────────────────────
# DIRECT_URL: direct DB host (used by Prisma Migrate)
DIRECT_URL=postgresql://USER:PASSWORD@db.<project-ref>.supabase.co:5432/postgres
# DATABASE_URL: Supabase pooler URL (used by Prisma Client at runtime)
# pgbouncer=true prevents prepared statement conflicts on pooled connections.
DATABASE_URL=postgresql://USER:PASSWORD@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# RAZORPAY
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─────────────────────────────────────────────
# PHONEPE (fallback)
# ─────────────────────────────────────────────
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_API_KEY=your_phonepe_api_key
PHONEPE_WEBHOOK_SECRET=your_phonepe_webhook_secret

# ─────────────────────────────────────────────
# CLOUDINARY
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────
# WHATSAPP (WATI)
# ─────────────────────────────────────────────
WATI_API_KEY=your_wati_api_key
WATI_API_ENDPOINT=https://live-server-XXXXX.wati.io
WATI_BUSINESS_PHONE=919948954545

# ─────────────────────────────────────────────
# FRONTEND URL (for CORS)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
